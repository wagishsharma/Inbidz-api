# Production — copy to apps/api/.env.local on the server (api.inbidz.com)
# Domains: app.inbidz.com · api.inbidz.com · id.inbidz.com (login)

# App DB (read/write) — commerce, feed, app_profiles
DB_HOST=
DB_USER=inbidz_app_api
DB_PASSWORD=
DB_NAME=inbidz_app
DB_PORT=3306

# Org DB (read-only) — login-time sync from inbidz_org
ORG_DB_HOST=
ORG_DB_USER=inbidz_org_app
ORG_DB_PASSWORD=
ORG_DB_NAME=inbidz_org
ORG_DB_PORT=3306

JWT_SECRET=
AUTH_LOGIN_APP_URL=https://id.inbidz.com
# For mirroring org profile photos (/api/uploads/...) to R2
ORG_PUBLIC_URL=https://www.inbidz.org

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_URL=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

APP_PUBLIC_URL=https://app.inbidz.com
API_PUBLIC_URL=https://api.inbidz.com
APP_SCHEME=inbidz

SHORT_URL_BASE=https://api.inbidz.com/p

APPLE_TEAM_ID=
APP_BUNDLE_ID=com.inbidz.app

ANDROID_SHA256_FINGERPRINT=
