DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=inbidz_app
DB_PORT=3306

JWT_SECRET=dev-jwt-secret-min-32-characters-long!!
AUTH_LOGIN_APP_URL=http://localhost:3002

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
# r2.dev public domain (R2 bucket → Settings → Public access → Enable)
R2_PUBLIC_URL=
# S3 credentials from Cloudflare R2 → Manage R2 API tokens (Object Read & Write on bucket)
# R2_TOKEN (cfat_...) is NOT used — only ACCESS_KEY_ID + SECRET_ACCESS_KEY

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Copy test keys from inbidz-com/.env.local for real checkout
# When empty in development, buy uses DEV test payments (confirm in app)

APP_PUBLIC_URL=http://localhost:8081
API_PUBLIC_URL=http://localhost:3001
APP_SCHEME=inbidz
# Public share links + OG previews (must be reachable by WhatsApp/iMessage crawlers in prod)
SHORT_URL_BASE=http://localhost:3001/p

# Staging template: see .env.staging.example
# APP_PUBLIC_URL=https://staging.inbidz.com
# API_PUBLIC_URL=https://staging-api.inbidz.com
# AUTH_LOGIN_APP_URL=https://staging-login.inbidz.com
# SHORT_URL_BASE=https://staging-api.inbidz.com/p
# APPLE_TEAM_ID=          # iOS Universal Links
# ANDROID_SHA256_FINGERPRINT=  # Android App Links
