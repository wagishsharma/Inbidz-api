# Staging — copy to your host env (Vercel, Railway, etc.)
# Domains: staging.inbidz.com · staging-api.inbidz.com · staging-login.inbidz.com

DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=inbidz_app_staging
DB_PORT=3306

JWT_SECRET=
AUTH_LOGIN_APP_URL=https://staging-login.inbidz.com

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_URL=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Mobile web (optional) + share landing fallback
APP_PUBLIC_URL=https://staging.inbidz.com
API_PUBLIC_URL=https://staging-api.inbidz.com
APP_SCHEME=inbidz

# Share links + OG previews (WhatsApp, iMessage)
SHORT_URL_BASE=https://staging-api.inbidz.com/p

# Universal Links (iOS) — Team ID from Apple Developer → Membership
APPLE_TEAM_ID=
APP_BUNDLE_ID=com.inbidz.app

# App Links (Android) — from EAS credentials or keytool -list -v
ANDROID_SHA256_FINGERPRINT=
